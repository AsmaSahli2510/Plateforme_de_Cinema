# Backend environment variables
# Copy this file to cinevent-backend/.env and fill in the values.

PORT=5000

# MongoDB connection string.
MONGO_URI=mongodb://127.0.0.1:27017/cineevent

# JSON Web Token secret – use a long random string in production
JWT_SECRET=supersecret

# Token expiry (e.g. 7d, 1h)
JWT_EXPIRE=7d
